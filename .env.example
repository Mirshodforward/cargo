# Bot
BOT_TOKEN=

# Google Sheets — bittasi majburiy:
# A) JSON fayl
# GOOGLE_SHEETS_CREDENTIALS_PATH=/path/to/service-account.json
#
# B) Butun JSON bir qatorda (kalit ichida \n → \\n)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
#
# C) Alohida maydonlar (private_key bir qatorda, qatorlar \n bilan)
# GOOGLE_SA_TYPE=service_account
# GOOGLE_SA_PROJECT_ID=
# GOOGLE_SA_PRIVATE_KEY_ID=
# GOOGLE_SA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# GOOGLE_SA_CLIENT_EMAIL=
# GOOGLE_SA_CLIENT_ID=
# GOOGLE_SA_CLIENT_X509_CERT_URL=
# (qolganlari ixtiyoriy — standart Google URL lar ishlatiladi)

GOOGLE_SPREADSHEET_ID=
GOOGLE_SHEETS_EXPORT_RANGE=Sheet1
GOOGLE_SHEETS_HEADER_ROWS=1
GOOGLE_SHEETS_KOD_HEADER=KOD
GOOGLE_SHEETS_SUM_COLUMNS=Paket soni,Og'irlik,Hajm,Summa
GOOGLE_SHEETS_TOTALS_TEXT=umumiy
GOOGLE_SHEETS_TOTALS_TEXT_COLUMN=Qabul sana
